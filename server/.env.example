# ── Database ─────────────────────────────────────────────────
# MongoDB connection string (required)
# Get a free cluster at https://www.mongodb.com/atlas
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/finio

# ── Authentication ───────────────────────────────────────────
# JWT signing secret — must be a long random string in production
# Generate one with: openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── AI (optional) ────────────────────────────────────────────
# Google Gemini API key — app falls back to local analysis if missing
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Development default: http://localhost:5173
# Production example:  https://finio.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# ── Server ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── API base URL ─────────────────────────────────────────────
# Leave empty for local development — the Vite dev server proxies
# all /api/* requests to localhost:4000 automatically (see vite.config.js)
#
# Set this only for production builds:
# VITE_API_BASE_URL=https://finio-api.onrender.com
VITE_API_BASE_URL=
